---
import CreativeClusterNav from "../../components/CreativeClusterNav.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { creativeCluster, replicaFooterCredit } from "../../data/editorial";
import { buildImageCollectionPageStructuredData, socialPreviewImages } from "../../data/site";

const landingPage = creativeCluster.landing;
const pageTitle = "Creative";
const pageDescription = "Creative cluster for Mark Jayson Martinez Farol.";
const siteOrigin = Astro.site ?? new URL("https://markjayson.com");
const pageUrl = new URL(Astro.url.pathname, siteOrigin).toString();
const landingImages = landingPage.headshotPreviews;
const structuredData = buildImageCollectionPageStructuredData(pageUrl, pageTitle, pageDescription, landingImages);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  page={landingPage.theme.page}
  accent={landingPage.theme.accent}
  shell="bare"
  footer={false}
  replicaFooter={false}
  replicaMotion={true}
  structuredData={structuredData}
  socialImage={socialPreviewImages.creativeLanding}
>
  <article class="replica-page creative-cluster-page creative-cluster-page--landing">
    <div class="replica-canvas creative-cluster-page__canvas">
      <div class="creative-cluster-page__shell">
        <CreativeClusterNav items={creativeCluster.nav} activeHref={creativeCluster.nav[0].href} />

        <header class="creative-cluster-page__header">
          <h1 class="creative-page__title" data-lift>{landingPage.title}</h1>
          <p class="creative-cluster-page__lead" data-lift>{landingPage.lead}</p>
        </header>

        <section class="creative-cluster-page__spotlight creative-landing__spotlight" aria-label="Creative spotlight">
          <figure class="creative-cluster-page__spotlight-figure creative-cluster-page__spotlight-figure--video creative-landing__video-frame" data-lift>
            <video
              class="creative-cluster-page__spotlight-video"
              src={landingPage.spotlightVideo.src}
              poster={landingPage.spotlightVideo.posterSrc}
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
              aria-hidden="true"
              tabindex="-1"
            ></video>
          </figure>

          <div class="creative-cluster-page__spotlight-copy creative-landing__story" data-lift>
            <p class="creative-cluster-page__section-label">Artistic Background</p>
            <p class="creative-cluster-page__statement creative-landing__statement">{landingPage.statement}</p>
          </div>
        </section>

        <section class="creative-landing__measurements" aria-label="Creative measurements" data-lift>
          <div class="creative-landing__measurements-grid">
            {
              landingPage.measurements.map((item) => (
                <div class="creative-landing__measurement">
                  <span class="creative-landing__measurement-label">{item.label}</span>
                  <span class="creative-landing__measurement-value">{item.value}</span>
                </div>
              ))
            }
          </div>
        </section>

        <section class="creative-landing__headshots" aria-labelledby="creative-headshots-preview-title">
          <div class="creative-landing__headshots-header" data-lift>
            <p id="creative-headshots-preview-title" class="creative-cluster-page__section-label">Headshots</p>
            <a class="creative-landing__headshots-link" href={landingPage.headshotsCta.href}>
              {landingPage.headshotsCta.label}
            </a>
          </div>

          <div class="creative-landing__headshots-grid">
            {
              landingPage.headshotPreviews.map((item) => (
                <figure class="creative-landing__headshot-card" data-lift>
                  <img class="creative-landing__headshot-image" src={item.src} alt={item.alt} loading="lazy" />
                </figure>
              ))
            }
          </div>
        </section>

        <section class="creative-cluster-page__grid creative-landing__grid" aria-label="Creative areas">
          <p class="creative-cluster-page__section-label">Creative Roles</p>
          {
            landingPage.featureCards.map((card) => (
              <article class="creative-feature-card creative-landing__card" data-lift>
                <div class="creative-feature-card__copy">
                  <h2>{card.title}</h2>
                  <p>{card.description}</p>
                </div>

                {card.href && card.cta && (
                  <a class="creative-feature-card__link" href={card.href}>
                    {card.cta}
                  </a>
                )}
              </article>
            ))
          }
        </section>
      </div>

      <p class="page-credit page-credit--light">{replicaFooterCredit}</p>
    </div>
  </article>
</BaseLayout>
