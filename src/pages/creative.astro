---
import BaseLayout from "../layouts/BaseLayout.astro";
import { creativePage, replicaFooterCredit } from "../data/editorial";
---

<BaseLayout
  title="Creative"
  description="Creative page for Mark Jayson Martinez Farol."
  page="creative"
  accent="#ba9838"
  shell="bare"
  footer={false}
  replicaFooter={false}
  replicaMotion={true}
>
  <article class="replica-page creative-page">
    <div class="replica-canvas creative-page__canvas">
      <p class="creative-page__eyebrow" data-lift>{creativePage.eyebrow}</p>
      <h1 class="creative-page__title" data-lift>{creativePage.title}</h1>
      <p class="creative-page__lead" data-lift>{creativePage.lead}</p>
      <p class="page-credit page-credit--light">{replicaFooterCredit}</p>
    </div>
  </article>
</BaseLayout>
