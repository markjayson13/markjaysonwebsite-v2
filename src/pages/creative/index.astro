---
import CreativeClusterNav from "../../components/CreativeClusterNav.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { creativeCluster, replicaFooterCredit } from "../../data/editorial";
import { buildImageCollectionPageStructuredData } from "../../data/site";

const landingPage = creativeCluster.landing;
const pageTitle = "Creative";
const pageDescription = "Creative cluster for Mark Jayson Martinez Farol.";
const siteOrigin = Astro.site ?? new URL("https://markjayson.com");
const pageUrl = new URL(Astro.url.pathname, siteOrigin).toString();
const landingImages = landingPage.featuredImage ? [landingPage.featuredImage] : [];
const structuredData = buildImageCollectionPageStructuredData(pageUrl, pageTitle, pageDescription, landingImages);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  page="creative"
  accent="#ba9838"
  shell="bare"
  footer={false}
  replicaFooter={false}
  replicaMotion={true}
  structuredData={structuredData}
>
  <article class="replica-page creative-cluster-page creative-cluster-page--landing">
    <div class="replica-canvas creative-cluster-page__canvas">
      <div class="creative-cluster-page__shell">
        <CreativeClusterNav items={creativeCluster.nav} activeHref={creativeCluster.nav[0].href} />

        <header class="creative-cluster-page__header">
          <p class="creative-page__eyebrow" data-lift>{landingPage.eyebrow}</p>
          <h1 class="creative-page__title" data-lift>{landingPage.title}</h1>
          <p class="creative-cluster-page__lead" data-lift>{landingPage.lead}</p>
        </header>

        <section class="creative-cluster-page__spotlight" data-lift>
          <div class="creative-cluster-page__spotlight-copy">
            <p class="creative-cluster-page__section-label">Artistic Background</p>
            <p class="creative-cluster-page__statement">{landingPage.statement}</p>
            {
              landingPage.background.map((paragraph) => (
                <p class="creative-cluster-page__copy">{paragraph}</p>
              ))
            }
          </div>

          <aside class="creative-cluster-page__spotlight-side">
            <figure class="creative-cluster-page__spotlight-figure creative-cluster-page__spotlight-figure--video" data-lift>
              <video
                class="creative-cluster-page__spotlight-video"
                src={landingPage.spotlightVideo.src}
                poster={landingPage.spotlightVideo.posterSrc}
                autoplay
                muted
                loop
                playsinline
                preload="metadata"
                aria-label={landingPage.spotlightVideo.alt}
              ></video>
              <figcaption class="creative-gallery__caption">Creative spotlight reel</figcaption>
            </figure>

            {
              landingPage.featuredImage && (
                <figure class="creative-cluster-page__spotlight-figure creative-cluster-page__spotlight-figure--supporting" data-lift>
                  <img
                    class="creative-cluster-page__spotlight-image"
                    src={landingPage.featuredImage.src}
                    alt={landingPage.featuredImage.alt}
                    loading="eager"
                  />
                  <figcaption class="creative-gallery__caption">{landingPage.featuredImage.caption}</figcaption>
                </figure>
              )
            }
          </aside>
        </section>

        <section class="creative-cluster-page__practice" data-lift>
          <div class="creative-cluster-page__practice-copy">
            <p class="creative-cluster-page__section-label">Practice</p>
            <div class="creative-cluster-page__skills">
              {
                landingPage.skills.map((skill) => (
                  <span class="creative-cluster-page__skill">{skill}</span>
                ))
              }
            </div>
          </div>

          <a class="replica-outline-button" href={landingPage.headshotsCta.href}>
            {landingPage.headshotsCta.label}
          </a>
        </section>

        <section class="creative-cluster-page__grid" aria-label="Creative areas">
          {
            landingPage.featureCards.map((card) => (
              <article class="creative-feature-card" data-lift>
                <div class="creative-feature-card__copy">
                  <h2>{card.title}</h2>
                  <p>{card.description}</p>
                  {card.note && <p class="creative-feature-card__note">{card.note}</p>}
                </div>

                {card.href && card.cta ? (
                  <a class="replica-outline-button" href={card.href}>
                    {card.cta}
                  </a>
                ) : (
                  <span class="creative-feature-card__status">Info block</span>
                )}
              </article>
            ))
          }
        </section>
      </div>

      <p class="page-credit page-credit--light">{replicaFooterCredit}</p>
    </div>
  </article>
</BaseLayout>
