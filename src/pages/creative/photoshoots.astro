---
import CreativeClusterNav from "../../components/CreativeClusterNav.astro";
import SectionRail from "../../components/SectionRail.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { creativeCluster, replicaFooterCredit } from "../../data/editorial";
import { buildImageCollectionPageStructuredData, socialPreviewImages } from "../../data/site";
import type { CreativeGalleryItem } from "../../data/editorial";

const photoshootsPage = creativeCluster.photoshoots;
const pageTitle = "Photoshoots";
const pageDescription = "Categorized photoshoots for Mark Jayson Martinez Farol.";
const siteOrigin = Astro.site ?? new URL("https://markjayson.com");
const pageUrl = new URL(Astro.url.pathname, siteOrigin).toString();
const allPhotoshootItems = photoshootsPage.groups.reduce<CreativeGalleryItem[]>(
  (items, group) => items.concat(group.items),
  [],
);
const structuredData = buildImageCollectionPageStructuredData(
  pageUrl,
  pageTitle,
  pageDescription,
  allPhotoshootItems,
);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  page="creative"
  accent="#ba9838"
  shell="bare"
  footer={false}
  replicaFooter={false}
  replicaMotion={true}
  structuredData={structuredData}
  socialImage={socialPreviewImages.creativePhotoshoots}
>
  <article class="replica-page creative-cluster-page creative-photos-page">
    <div class="replica-canvas creative-cluster-page__canvas">
      <div class="creative-cluster-page__shell">
        <CreativeClusterNav items={creativeCluster.nav} activeHref={creativeCluster.nav[3].href} />

        <header class="creative-cluster-page__header creative-cluster-page__header--narrow">
          <p class="creative-page__eyebrow" data-lift>Visual Archive</p>
          <h1 class="creative-page__title" data-lift>{photoshootsPage.title}</h1>
          <p class="creative-cluster-page__lead" data-lift>{photoshootsPage.lead}</p>
        </header>

        <div class="rail-page__layout rail-page__layout--light creative-photos-page__layout" data-section-rail-root data-default-panel={photoshootsPage.defaultId}>
          <SectionRail title={photoshootsPage.title} items={photoshootsPage.rail} activeId={photoshootsPage.defaultId} />

          <div class="rail-page__content creative-photos-page__content">
            {
              photoshootsPage.groups.map((group) => {
                const leadItem = group.items.find((item) => item.featured) ?? group.items[0];
                const supportingItems = group.items.filter((item) => item.src !== leadItem?.src);

                return (
                  <section
                    id={`rail-panel-${group.id}`}
                    class="rail-page__group"
                    data-rail-panel
                    data-section-id={group.id}
                    role="tabpanel"
                    aria-labelledby={`rail-tab-${group.id}`}
                    hidden={group.id !== photoshootsPage.defaultId}
                  >
                    <div class="creative-photos-page__panel-hero">
                      <div class="creative-photos-page__panel-copy" data-lift>
                        <p class="creative-cluster-page__section-label">Series</p>
                        <h2 class="rail-page__group-title">{group.label}</h2>
                        <p class="rail-page__group-intro">{group.intro}</p>
                      </div>

                      {
                        leadItem && (
                          <figure
                            class:list={[
                              "creative-gallery__figure",
                              "creative-gallery__figure--lead",
                              "creative-photos-page__lead",
                              leadItem.aspect === "landscape" && "creative-gallery__figure--landscape",
                              leadItem.aspect === "portrait" && "creative-gallery__figure--portrait",
                            ]}
                            data-lift
                          >
                            <img
                              class:list={[
                                "creative-gallery__image",
                                "creative-gallery__image--lead",
                                leadItem.aspect === "landscape" && "creative-gallery__image--landscape",
                                leadItem.aspect === "portrait" && "creative-gallery__image--portrait",
                              ]}
                              src={leadItem.src}
                              alt={leadItem.alt}
                              loading="eager"
                            />
                            <figcaption class="creative-gallery__caption">{leadItem.caption}</figcaption>
                          </figure>
                        )
                      }
                    </div>

                    <div class="creative-gallery creative-gallery--photos">
                      {
                        supportingItems.map((item) => (
                          <figure class="creative-gallery__figure" data-lift>
                            <img class="creative-gallery__image" src={item.src} alt={item.alt} loading="lazy" />
                            <figcaption class="creative-gallery__caption">{item.caption}</figcaption>
                          </figure>
                        ))
                      }
                    </div>
                  </section>
                );
              })
            }
          </div>
        </div>
      </div>

      <p class="page-credit page-credit--light">{replicaFooterCredit}</p>
    </div>
  </article>
</BaseLayout>
