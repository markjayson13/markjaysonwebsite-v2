---
import CreativeClusterNav from "../../components/CreativeClusterNav.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { creativeCluster, replicaFooterCredit } from "../../data/editorial";
import { buildImageCollectionPageStructuredData, socialPreviewImages } from "../../data/site";

const headshotsPage = creativeCluster.headshots;
const primaryHeadshot = headshotsPage.items.find((item) => item.featured) ?? headshotsPage.items[0];
const supportingHeadshots = headshotsPage.items.filter((item) => item.src !== primaryHeadshot?.src);
const pageTitle = "Headshots";
const pageDescription = "Headshots and portrait studies for Mark Jayson Martinez Farol.";
const siteOrigin = Astro.site ?? new URL("https://markjayson.com");
const pageUrl = new URL(Astro.url.pathname, siteOrigin).toString();
const structuredData = buildImageCollectionPageStructuredData(pageUrl, pageTitle, pageDescription, headshotsPage.items);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  page={headshotsPage.theme.page}
  accent={headshotsPage.theme.accent}
  shell="bare"
  footer={false}
  replicaFooter={false}
  replicaMotion={true}
  structuredData={structuredData}
  socialImage={socialPreviewImages.creativeHeadshots}
>
  <article class="replica-page creative-cluster-page creative-gallery-page">
    <div class="replica-canvas creative-cluster-page__canvas">
      <div class="creative-cluster-page__shell">
        <CreativeClusterNav items={creativeCluster.nav} activeHref={creativeCluster.nav[2].href} />

        <header class="creative-cluster-page__header creative-cluster-page__header--centered creative-headshots__header">
          <h1 class="creative-page__title" data-lift>{headshotsPage.title}</h1>
        </header>

        <section class="creative-headshots__stage" aria-label="Headshot gallery">
          {
            primaryHeadshot && (
              <figure class="creative-headshots__primary" data-lift>
                <img
                  class="creative-headshots__primary-image"
                  src={primaryHeadshot.src}
                  alt={primaryHeadshot.alt}
                  loading="eager"
                />
              </figure>
            )
          }

          <div class="creative-headshots__supporting">
            {
              supportingHeadshots.map((item) => (
                <figure class="creative-gallery__figure creative-headshots__supporting-card" data-lift>
                  <img class="creative-gallery__image creative-headshots__supporting-image" src={item.src} alt={item.alt} loading="lazy" />
                </figure>
              ))
            }
          </div>
        </section>
      </div>

      <p class="page-credit page-credit--light">{replicaFooterCredit}</p>
    </div>
  </article>
</BaseLayout>
