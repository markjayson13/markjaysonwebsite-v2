---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionRail from "../components/SectionRail.astro";
import { projectsPage, replicaFooterCredit } from "../data/editorial";
import type { ProjectEntry } from "../data/editorial";

const panels: { id: string; title: string; intro: string; entries: ProjectEntry[] }[] = [
  {
    id: projectsPage.latest.id,
    title: projectsPage.latest.label,
    intro: projectsPage.latest.intro,
    entries: projectsPage.latest.entries,
  },
  ...projectsPage.sections.map((section) => ({
    id: section.id,
    title: section.label,
    intro: section.intro,
    entries: section.entries,
  })),
];
---

<BaseLayout
  title="Projects"
  description="Projects page for Mark Jayson Martinez Farol."
  page="projects"
  accent="#171c7c"
  shell="bare"
  footer={false}
  replicaFooter={false}
  replicaMotion={true}
>
  <article class="replica-page projects-page">
    <div class="replica-canvas projects-page__canvas">
      <header class="rail-page__header rail-page__header--light">
        <h1 class="rail-page__title" data-lift>{projectsPage.title}</h1>
        <p class="rail-page__lead" data-lift>{projectsPage.lead}</p>
      </header>

      <div class="rail-page__layout rail-page__layout--light" data-section-rail-root data-default-panel={projectsPage.latest.id}>
        <SectionRail title={projectsPage.title} items={projectsPage.rail} activeId={projectsPage.latest.id} />

        <div class="rail-page__content">
          {
            panels.map((panel) => (
              <section
                id={`rail-panel-${panel.id}`}
                class="rail-page__group"
                data-rail-panel
                data-section-id={panel.id}
                role="tabpanel"
                aria-labelledby={`rail-tab-${panel.id}`}
                hidden={panel.id !== projectsPage.latest.id}
              >
                <h2 class="rail-page__group-title">{panel.title}</h2>
                <p class="rail-page__group-intro">{panel.intro}</p>

                <div class="rail-page__entries">
                  {
                    panel.entries.map((entry) => (
                      <article class="rail-entry rail-entry--light" data-lift>
                        <h3>{entry.title}</h3>
                        <p>{entry.summary}</p>
                        {
                          entry.ctaLabel &&
                            (entry.href ? (
                              <a class="replica-outline-button" href={entry.href} target="_blank" rel="noreferrer">
                                {entry.ctaLabel}
                              </a>
                            ) : (
                              <span class="replica-outline-button is-disabled">{entry.ctaLabel}</span>
                            ))
                        }
                      </article>
                    ))
                  }
                </div>
              </section>
            ))
          }
        </div>
      </div>

      <footer class="rail-page__footer rail-page__footer--light">
        <p class="page-credit page-credit--light">{replicaFooterCredit}</p>
      </footer>
    </div>
  </article>
</BaseLayout>
