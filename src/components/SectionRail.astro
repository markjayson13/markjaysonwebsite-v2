---
import type { RailItem } from "../data/editorial";

interface Props {
  title: string;
  items: RailItem[];
  activeId?: string;
}

const { title, items, activeId = items[0]?.id } = Astro.props;
---

<nav class="section-rail" aria-label={`${title} section navigation`} data-section-rail>
  <p class="section-rail__title">{title}</p>
  <div class="section-rail__items" role="tablist" aria-label={`${title} filters`} aria-orientation="horizontal">
    {
      items.map((item) => (
        <button
          type="button"
          id={`rail-tab-${item.id}`}
          class:list={["section-rail__link", item.id === activeId && "is-active"]}
          data-rail-link
          data-target={item.id}
          role="tab"
          aria-controls={`rail-panel-${item.id}`}
          aria-selected={item.id === activeId ? "true" : "false"}
          tabindex={item.id === activeId ? "0" : "-1"}
        >
          {item.label}
        </button>
      ))
    }
  </div>
</nav>
