---
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../utils/paths";

const pageTitle = "Economics Projects";
const pageDescription =
  "Economics project work for Mark Jayson Farol is being prepared for public release.";
const robots = "noindex,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  page="projects"
  accent="#050505"
  robots={robots}
  shell="bare"
  footer={false}
  replicaFooter={false}
  replicaMotion={true}
>
  <article class="replica-page legal-page">
    <div class="replica-canvas legal-page__canvas">
      <header class="legal-page__header">
        <p class="legal-page__eyebrow">Economics</p>
        <h1 class="legal-page__title" data-lift>Economics Projects</h1>
        <p class="legal-page__lead" data-lift>
          A dedicated economics-projects page is coming soon. For now, the public portfolio
          already covers econometrics, higher-education finance, analytical systems, and
          decision-focused research work.
        </p>
      </header>

      <div class="legal-page__sections">
        <section class="legal-page__section" data-lift>
          <h2>Status</h2>
          <p>
            This landing page is a temporary holding page while the economics-specific project
            collection is being packaged for publication.
          </p>
        </section>

        <section class="legal-page__section" data-lift>
          <h2>Available Now</h2>
          <p>
            The current portfolio already includes research, project infrastructure, and
            publications tied to econometrics, policy analysis, and finance-related work.
          </p>
          <a class="replica-outline-button replica-outline-button--dark" href={withBase("/portfolio#research")}>
            View Portfolio
          </a>
        </section>
      </div>
    </div>
  </article>
</BaseLayout>
