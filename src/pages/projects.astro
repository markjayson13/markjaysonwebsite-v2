---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionRail from "../components/SectionRail.astro";
import { projectsPage, replicaFooterCredit } from "../data/editorial";
---

<BaseLayout
  title="Projects"
  description="Projects page for Mark Jayson Martinez Farol."
  page="projects"
  accent="#171c7c"
  shell="bare"
  footer={false}
  replicaFooter={false}
  replicaMotion={true}
>
  <article class="replica-page projects-page">
    <div class="replica-canvas projects-page__canvas">
      <header class="rail-page__header rail-page__header--light">
        <h1 class="rail-page__title" data-lift>{projectsPage.title}</h1>
        <p class="rail-page__lead" data-lift>{projectsPage.lead}</p>
      </header>

      <div class="rail-page__layout rail-page__layout--light" data-section-rail-root>
        <SectionRail title={projectsPage.title} items={projectsPage.rail} />

        <div class="rail-page__content">
          {
            projectsPage.sections.map((section) => (
              <section id={section.id} class="rail-page__group" data-rail-section data-section-id={section.id}>
                <h2 class="rail-page__group-title">{section.label}</h2>
                <p class="rail-page__group-intro">{section.intro}</p>

                <div class="rail-page__entries">
                  {
                    section.entries.map((entry) => (
                      <article class="rail-entry rail-entry--light" data-lift>
                        <h3>{entry.title}</h3>
                        <p>{entry.summary}</p>
                        {
                          entry.ctaLabel &&
                            (entry.href ? (
                              <a class="replica-outline-button" href={entry.href} target="_blank" rel="noreferrer">
                                {entry.ctaLabel}
                              </a>
                            ) : (
                              <span class="replica-outline-button is-disabled">{entry.ctaLabel}</span>
                            ))
                        }
                      </article>
                    ))
                  }
                </div>
              </section>
            ))
          }
        </div>
      </div>

      <p class="page-credit page-credit--light">{replicaFooterCredit}</p>
    </div>
  </article>
</BaseLayout>
