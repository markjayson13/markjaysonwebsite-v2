---
import { canonicalSiteUrl, footerContact, footerLegalLinks, footerSecondaryLinks, footerSocialLinks, profile } from "../data/site";
import SocialIcon from "./SocialIcon.astro";

const currentYear = new Date().getFullYear();
const siteLabel = canonicalSiteUrl.replace(/^https?:\/\//, "");
---

<footer class="site-footer" aria-labelledby="site-footer-title">
  <div class="site-footer__inner">
    <div class="site-footer__brand">
      <p class="site-footer__eyebrow">{siteLabel}</p>
      <h2 id="site-footer-title" class="site-footer__title">{profile.fullName}</h2>
      <p class="site-footer__copyright">© {currentYear} {profile.fullName}</p>
    </div>

    <section class="site-footer__contact" aria-labelledby="site-footer-contact-title">
      <p id="site-footer-contact-title" class="site-footer__section-title">Contact</p>
      <p class="site-footer__contact-link" aria-label={`Email ${footerContact.email}`}>{footerContact.email}</p>
      <p class="site-footer__contact-copy">{footerContact.location}</p>
      <a class="site-footer__button" href={footerContact.buttonHref}>{footerContact.buttonLabel}</a>
    </section>

    <nav class="site-footer__nav" aria-labelledby="site-footer-nav-title">
      <p id="site-footer-nav-title" class="site-footer__section-title">Navigation</p>
      <div class="site-footer__link-grid">
        {
          footerSecondaryLinks.map((link) => (
            <a class="site-footer__link" href={link.href}>
              {link.label}
            </a>
          ))
        }
      </div>
    </nav>

    <section class="site-footer__social" aria-labelledby="site-footer-social-title">
      <p id="site-footer-social-title" class="site-footer__section-title">Profiles</p>
      <div class="site-footer__social-grid">
        {
          footerSocialLinks.map((link) =>
            link.enabled && link.href ? (
              <a class="site-footer__social-link" href={link.href} target="_blank" rel="noreferrer" aria-label={link.label}>
                <span class="site-footer__social-icon"><SocialIcon icon={link.icon} /></span>
              </a>
            ) : (
              <span class="site-footer__social-link site-footer__social-link--disabled" aria-label={link.label}>
                <span class="site-footer__social-icon"><SocialIcon icon={link.icon} /></span>
              </span>
            ),
          )
        }
      </div>
    </section>

    <nav class="site-footer__legal" aria-labelledby="site-footer-legal-title">
      <p id="site-footer-legal-title" class="site-footer__section-title">Legal</p>
      <div class="site-footer__legal-links">
        {
          footerLegalLinks.map((link) => (
            <a class="site-footer__link" href={link.href}>
              {link.label}
            </a>
          ))
        }
      </div>
    </nav>
  </div>
</footer>
