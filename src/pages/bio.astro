---
import BaseLayout from "../layouts/BaseLayout.astro";
import { bioPage, replicaFooterCredit } from "../data/editorial";
import { buildPrimaryImageStructuredData, buildProfilePageStructuredData, socialPreviewImages } from "../data/site";
const pageTitle = "About";
const pageDescription =
  "Professional overview for Mark Jayson Martinez Farol, an economist and data scientist focused on econometrics, causal inference, and data engineering.";
const siteOrigin = Astro.site ?? new URL("https://markjayson.com");
const pageUrl = new URL(Astro.url.pathname, siteOrigin).toString();
const structuredData = [
  ...buildProfilePageStructuredData(pageUrl, pageTitle, pageDescription),
  ...buildPrimaryImageStructuredData(pageUrl, {
    src: bioPage.portraitSrc,
    alt: "Portrait of Mark Jayson Farol.",
    caption: "Primary portrait of Mark Jayson Farol",
  }),
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  page="bio"
  accent="#edf0f2"
  shell="bare"
  footer={false}
  replicaFooter={false}
  replicaMotion={true}
  structuredData={structuredData}
  socialImage={socialPreviewImages.bio}
>
  <article class="replica-page bio-page">
    <div class="replica-canvas bio-page__canvas">
      <h1 class="bio-page__title" data-lift>{bioPage.title}</h1>

      <div class="bio-page__body">
        <div class="bio-page__copy">
          <p class="bio-page__eyebrow" data-lift>About</p>
          {
            bioPage.paragraphs.map((paragraph) => (
              <p data-lift>{paragraph}</p>
            ))
          }

          <div class="bio-page__links" data-lift>
            <p class="bio-page__links-label">Explore</p>
            {
              bioPage.links.map((link) => (
                <a class="replica-black-card" href={link.href}>
                  {link.label}
                </a>
              ))
            }
          </div>
        </div>

        <div class="bio-page__portrait" data-lift>
          <img src={bioPage.visiblePortraitSrc} alt="Cutout portrait of Mark Jayson Farol." loading="eager" />
        </div>
      </div>

      <p class="page-credit page-credit--dark">{replicaFooterCredit}</p>
    </div>
  </article>
</BaseLayout>
