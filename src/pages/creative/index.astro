---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { creativeCluster, replicaFooterCredit } from "../../data/editorial";
import { buildImageCollectionPageStructuredData, socialPreviewImages } from "../../data/site";

const landingPage = creativeCluster.landing;
const pageTitle = "Creative";
const pageDescription = "Creative cluster for Mark Jayson Martinez Farol.";
const siteOrigin = Astro.site ?? new URL("https://markjayson.com");
const pageUrl = new URL(Astro.url.pathname, siteOrigin).toString();
const landingImages = landingPage.headshotPreviews;
const structuredData = buildImageCollectionPageStructuredData(pageUrl, pageTitle, pageDescription, landingImages);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  page={landingPage.theme.page}
  accent={landingPage.theme.accent}
  shell="bare"
  footer={false}
  replicaFooter={false}
  replicaMotion={true}
  structuredData={structuredData}
  socialImage={socialPreviewImages.creativeLanding}
>
  <article class="replica-page creative-cluster-page creative-cluster-page--landing">
    <div class="replica-canvas creative-cluster-page__canvas">
      <div class="creative-cluster-page__shell">
        <header class="creative-cluster-page__header">
          <h1 class="creative-page__title" data-lift>{landingPage.title}</h1>
          <p class="creative-cluster-page__lead" data-lift>{landingPage.lead}</p>
        </header>

        <section class="creative-landing__story-shell creative-landing__story-shell--stacked" aria-labelledby="creative-spotlight-title">
          <div class="creative-landing__story-column creative-landing__story-column--full" data-lift>
            <p id="creative-spotlight-title" class="creative-cluster-page__section-label">Artistic Background</p>
            <p class="creative-cluster-page__statement creative-landing__statement">{landingPage.statement}</p>
          </div>

          <div class="creative-landing__utility-column" data-lift>
            <section class="creative-landing__headshots" aria-labelledby="creative-headshots-preview-title">
              <p id="creative-headshots-preview-title" class="sr-only">Headshot preview strip</p>
              <div class="creative-landing__headshots-grid">
                {
                  landingPage.headshotPreviews.map((item, index) => (
                    <a class="creative-landing__headshot-link" href={landingPage.headshotsCta.href} aria-label={`Open headshots page: ${item.alt}`}>
                      <figure class="creative-landing__headshot-card">
                        <img
                          class="creative-landing__headshot-image"
                          src={item.src}
                          alt=""
                          loading={index === 0 ? "eager" : "lazy"}
                          decoding="async"
                          fetchpriority={index === 0 ? "high" : undefined}
                        />
                      </figure>
                    </a>
                  ))
                }
              </div>

              <div class="creative-landing__headshots-cta">
                <a class="creative-landing__headshots-link" href={landingPage.headshotsCta.href}>
                  {landingPage.headshotsCta.label}
                </a>
              </div>
            </section>

            <section class="creative-landing__measurements creative-landing__measurements--stacked" aria-labelledby="creative-measurements-title">
              <p id="creative-measurements-title" class="sr-only">Measurements</p>
              <div class="creative-landing__measurements-grid">
                {
                  landingPage.measurements.map((item) => (
                    <div class="creative-landing__measurement">
                      <span class="creative-landing__measurement-label">{item.label}</span>
                      <span class="creative-landing__measurement-arrow" aria-hidden="true">→</span>
                      <span class="creative-landing__measurement-value">{item.value}</span>
                    </div>
                  ))
                }
              </div>
            </section>
          </div>
        </section>

        <section class="creative-cluster-page__grid creative-landing__grid" aria-labelledby="creative-roles-title">
          <p id="creative-roles-title" class="sr-only">Creative roles</p>
          {
            landingPage.featureCards.map((card) => (
              <article class:list={["creative-feature-card", "creative-landing__card", card.href && "creative-feature-card--linked"]} data-lift>
                <div class="creative-feature-card__copy">
                  <h2>
                    {
                      card.href ? (
                        <a class="creative-feature-card__title-link" href={card.href}>
                          {card.title}
                        </a>
                      ) : (
                        card.title
                      )
                    }
                  </h2>
                  <p>{card.description}</p>
                </div>

                {card.href && card.cta && (
                  <a class="creative-feature-card__link" href={card.href}>
                    {card.cta}
                  </a>
                )}
              </article>
            ))
          }
        </section>
      </div>

      <p class="page-credit page-credit--light">{replicaFooterCredit}</p>
    </div>
  </article>
</BaseLayout>
