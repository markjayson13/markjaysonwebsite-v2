---
import CreativeClusterNav from "../../components/CreativeClusterNav.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { creativeCluster, replicaFooterCredit } from "../../data/editorial";

const headshotsPage = creativeCluster.headshots;
const [primaryHeadshot, ...supportingHeadshots] = headshotsPage.items;
---

<BaseLayout
  title="Headshots"
  description="Headshots and portrait studies for Mark Jayson Martinez Farol."
  page="creative"
  accent="#ba9838"
  shell="bare"
  footer={false}
  replicaFooter={false}
  replicaMotion={true}
>
  <article class="replica-page creative-cluster-page creative-gallery-page">
    <div class="replica-canvas creative-cluster-page__canvas">
      <div class="creative-cluster-page__shell">
        <CreativeClusterNav items={creativeCluster.nav} activeHref={creativeCluster.nav[2].href} />

        <header class="creative-cluster-page__header creative-cluster-page__header--split">
          <div class="creative-cluster-page__header-copy">
            <p class="creative-page__eyebrow" data-lift>Portrait Archive</p>
            <h1 class="creative-page__title" data-lift>{headshotsPage.title}</h1>
            <p class="creative-cluster-page__lead" data-lift>{headshotsPage.lead}</p>
          </div>

          {
            headshotsPage.backstageHref && (
              <a class="replica-outline-button" href={headshotsPage.backstageHref} target="_blank" rel="noreferrer">
                View Backstage
              </a>
            )
          }
        </header>

        <section class="creative-headshots__lead" aria-label="Headshot spotlight">
          <figure class="creative-headshots__video" data-lift>
            <video
              class="creative-headshots__video-element"
              src={headshotsPage.introVideo.src}
              poster={headshotsPage.introVideo.posterSrc}
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
              aria-label={headshotsPage.introVideo.alt}
            ></video>
            <figcaption class="creative-gallery__caption">Portrait reel</figcaption>
          </figure>

          {
            primaryHeadshot && (
              <figure class="creative-headshots__primary" data-lift>
                <img
                  class="creative-headshots__primary-image"
                  src={primaryHeadshot.src}
                  alt={primaryHeadshot.alt}
                  loading="eager"
                />
                <figcaption class="creative-gallery__caption">{primaryHeadshot.caption}</figcaption>
              </figure>
            )
          }
        </section>

        <section class="creative-gallery creative-gallery--headshots" aria-label="Headshot gallery">
          {
            supportingHeadshots.map((item) => (
              <figure class="creative-gallery__figure" data-lift>
                <img class="creative-gallery__image" src={item.src} alt={item.alt} loading="lazy" />
                <figcaption class="creative-gallery__caption">{item.caption}</figcaption>
              </figure>
            ))
          }
        </section>
      </div>

      <p class="page-credit page-credit--light">{replicaFooterCredit}</p>
    </div>
  </article>
</BaseLayout>
