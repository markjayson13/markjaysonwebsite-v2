---
import {
  cornerMenuItems,
  creativeSiteUrl,
  mainSiteTopLinks,
  pageThemes,
  profile,
  socialPreviewImages,
  withCreativeSite,
} from "../data/site";
import type { SocialPreviewImage, StructuredData } from "../data/site";
import ReplicaMotion from "../components/ReplicaMotion.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { withBase } from "../utils/paths";
import "../styles/global.css";
import "../styles/editorial.css";

interface Props {
  title: string;
  description: string;
  page: string;
  accent?: string;
  robots?: string;
  shell?: "bare";
  footer?: boolean;
  replicaFooter?: boolean;
  replicaMotion?: boolean;
  structuredData?: StructuredData;
  socialImage?: SocialPreviewImage;
}

const {
  title,
  description,
  page,
  accent = "#0f6d63",
  robots,
  replicaMotion = true,
  structuredData,
  socialImage,
} = Astro.props;

const siteOrigin = Astro.site ?? new URL("https://markjayson.com");
const creativeOrigin = new URL(creativeSiteUrl);
const pageGroup = page.startsWith("creative-") ? "creative" : page;
const isCreativeHost = siteOrigin.hostname === creativeOrigin.hostname;
const canonicalOrigin = pageGroup === "creative" ? creativeOrigin : siteOrigin;
const canonical = new URL(Astro.url.pathname, canonicalOrigin).toString();
const structuredDataJson = structuredData ? JSON.stringify(structuredData, null, 2) : null;
const previewImage = socialImage ?? socialPreviewImages.home;
const previewImageUrl = new URL(previewImage.src, siteOrigin).toString();
const pageTheme = pageThemes[page] ?? pageThemes[pageGroup] ?? pageThemes.home;
const defaultRobots = "index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1";
const robotsContent =
  robots ??
  (pageGroup === "creative" && !isCreativeHost
    ? `noindex,follow,${defaultRobots.split(",").slice(2).join(",")}`
    : defaultRobots);
const cornerMenuDefaultLabelMap: Record<string, string> = {
  home: "About",
  bio: "About",
  resume: "Resume/CV",
  portfolio: "Portfolio",
  research: "Portfolio",
  projects: "Portfolio",
  articles: "Portfolio",
  profiles: "Profiles",
  privacy: "About",
  terms: "About",
};
const cornerMenuDefaultLabel = cornerMenuDefaultLabelMap[pageGroup] ?? "About";
const mainSiteTopRowPages = new Set(["home", "bio", "resume", "portfolio", "profiles"]);
const showMainSiteTopRow = mainSiteTopRowPages.has(page);
const backLinkFallbackMap: Record<string, string> = {
  bio: withBase("/"),
  resume: withBase("/"),
  portfolio: withBase("/"),
  profiles: withBase("/"),
  privacy: withBase("/"),
  terms: withBase("/"),
  research: withBase("/portfolio"),
  projects: withBase("/portfolio"),
  articles: withBase("/portfolio"),
  "creative-landing": withBase("/portfolio"),
  "creative-artistic-resume": withCreativeSite("/"),
  "creative-headshots": withCreativeSite("/"),
  "creative-photoshoots": withCreativeSite("/"),
};
const backLinkHref =
  page === "home" || showMainSiteTopRow ? null : backLinkFallbackMap[page] ?? backLinkFallbackMap[pageGroup] ?? withBase("/");
const isActiveMainSiteLink = (href?: string) => {
  if (!href) {
    return false;
  }

  try {
    const linkUrl = new URL(href, canonicalOrigin);
    return linkUrl.origin === siteOrigin.origin && linkUrl.pathname === Astro.url.pathname;
  } catch {
    return false;
  }
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | {profile.name}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    <meta name="googlebot" content={robotsContent} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={withBase("/favicon.svg")} type="image/svg+xml" />
    <link rel="icon" href={withBase("/favicon.ico")} sizes="any" />
    <link rel="icon" href={withBase("/favicon-48x48.png")} type="image/png" sizes="48x48" />
    <link rel="icon" href={withBase("/favicon-96x96.png")} type="image/png" sizes="96x96" />
    <link rel="apple-touch-icon" href={withBase("/apple-touch-icon.png")} sizes="180x180" />
    <meta name="theme-color" content={accent} />
    <meta property="og:title" content={`${title} | ${profile.name}`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={profile.name} />
    <meta property="og:image" content={previewImageUrl} />
    <meta property="og:image:alt" content={previewImage.alt} />
    {previewImage.width && <meta property="og:image:width" content={String(previewImage.width)} />}
    {previewImage.height && <meta property="og:image:height" content={String(previewImage.height)} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={previewImageUrl} />
    <meta name="twitter:image:alt" content={previewImage.alt} />
    {structuredDataJson && <script is:inline type="application/ld+json" set:html={structuredDataJson}></script>}
    <link rel="preload" href={withBase("/fonts/arimo-regular.woff2")} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={withBase("/fonts/arimo-bold.woff2")} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={withBase("/fonts/itc-franklin-gothic-lt-regular.woff2")} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={withBase("/fonts/itc-franklin-gothic-lt-semibold.woff2")} as="font" type="font/woff2" crossorigin />
    <link
      rel="preload"
      href={withBase("/fonts/itc-franklin-gothic-lt-condensed-regular.woff2")}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href={withBase("/fonts/itc-franklin-gothic-lt-condensed-semibold.woff2")}
      as="font"
      type="font/woff2"
      crossorigin
    />
  </head>

  <body
    class="has-site-footer"
    data-page={page}
    data-page-group={pageGroup}
    style={`--page-accent:${accent}; --page-title-measure:${pageTheme.titleMeasure}; --page-lead-measure:${pageTheme.leadMeasure}; --page-copy-measure:${pageTheme.copyMeasure ?? pageTheme.leadMeasure};`}
  >
    {
      showMainSiteTopRow && (
        <header class="site-top-row-shell" data-site-top-row>
          <div class="site-top-row-shell__inner">
            <nav class="site-top-row" aria-label="Main site sections">
              {
                mainSiteTopLinks.map((link) =>
                  link.menuTrigger ? (
                    <button class="site-top-row__link" type="button" data-site-menu-launch>
                      {link.label}
                    </button>
                  ) : (
                    <a class="site-top-row__link" href={link.href} aria-current={isActiveMainSiteLink(link.href) ? "page" : undefined}>
                      {link.label}
                    </a>
                  ),
                )
              }
            </nav>
          </div>
        </header>
      )
    }

    {
      backLinkHref && (
        <a class="site-back-link" href={backLinkHref} aria-label="Go back" title="Go back" data-site-back>
          <span aria-hidden="true">←</span>
        </a>
      )
    }

    <main id="main-content" class="site-main site-main--bare">
      <slot />
    </main>

    <SiteFooter />

    <div class="corner-menu" data-corner-menu-root data-default-label={cornerMenuDefaultLabel}>
      <span class="corner-menu__trigger-label" aria-hidden="true">What do you want to find Out?</span>
      <button
        class="corner-menu__trigger"
        type="button"
        aria-label="What do you want to find Out?"
        aria-expanded="false"
        aria-haspopup="dialog"
        aria-controls="site-corner-menu-panel"
        data-corner-menu-trigger
      >
        <span class="corner-menu__trigger-icon" aria-hidden="true">
          <span class="corner-menu__trigger-bar"></span>
          <span class="corner-menu__trigger-bar"></span>
          <span class="corner-menu__trigger-bar"></span>
        </span>
      </button>

      <div class="corner-menu__overlay" hidden data-corner-menu-overlay>
        <button class="corner-menu__backdrop" type="button" aria-label="Close navigation menu" data-corner-menu-close></button>

        <section
          id="site-corner-menu-panel"
          class="corner-menu__panel replica-menu-sheet replica-menu-sheet--overlay"
          role="dialog"
          aria-modal="true"
          aria-labelledby="corner-menu-title"
          data-preview-menu-root
          data-default-label={cornerMenuDefaultLabel}
        >
          <button class="corner-menu__panel-close" type="button" aria-label="Close navigation menu" data-corner-menu-close>
            Close
          </button>

          <h2 id="corner-menu-title" class="replica-menu-sheet__title">What do you want to find Out?</h2>

          <div class="replica-menu-sheet__layout">
            <nav class="replica-menu-sheet__nav" aria-label="Site navigation" data-menu-nav>
              {
                cornerMenuItems.map((item) => (
                  <a
                    href={item.href}
                    class="replica-menu-sheet__link"
                    data-menu-item
                    data-title={item.title}
                    data-description={item.description}
                    data-label={item.label}
                  >
                    {item.label}
                  </a>
                ))
              }
            </nav>

            <div class="replica-menu-sheet__preview">
              <h3 data-menu-preview-title></h3>
              <p data-menu-preview-description></p>
            </div>
          </div>
        </section>
      </div>
    </div>

    <script is:inline>
      const setupCornerMenu = () => {
        const root = document.querySelector("[data-corner-menu-root]");
        if (!(root instanceof HTMLElement) || root.dataset.menuInitialized === "true") {
          return;
        }

        root.dataset.menuInitialized = "true";

        const trigger = root.querySelector("[data-corner-menu-trigger]");
        const overlay = root.querySelector("[data-corner-menu-overlay]");
        const closeButtons = root.querySelectorAll("[data-corner-menu-close]");
        const defaultLabel = root.dataset.defaultLabel ?? "About";

        if (!(trigger instanceof HTMLButtonElement) || !(overlay instanceof HTMLElement)) {
          return;
        }

        const bindPreviewMenu = (menuRoot) => {
          if (!(menuRoot instanceof HTMLElement) || menuRoot.dataset.previewBound === "true") {
            return null;
          }

          menuRoot.dataset.previewBound = "true";
          const nav = menuRoot.querySelector("[data-menu-nav]");
          const items = Array.from(menuRoot.querySelectorAll("[data-menu-item]")).filter(
            (item) => item instanceof HTMLElement,
          );
          const titleEl = menuRoot.querySelector("[data-menu-preview-title]");
          const descriptionEl = menuRoot.querySelector("[data-menu-preview-description]");
          const menuDefaultLabel = menuRoot.dataset.defaultLabel ?? defaultLabel;

          const getItemByLabel = (label) =>
            items.find((item) => item instanceof HTMLElement && item.dataset.label === label);

          const setPreview = (label) => {
            const active = getItemByLabel(label);
            if (!(active instanceof HTMLElement)) {
              return null;
            }

            items.forEach((item) => {
              if (item instanceof HTMLElement) {
                item.classList.toggle("is-active", item === active);
              }
            });

            if (titleEl instanceof HTMLElement) {
              titleEl.textContent = active.dataset.title ?? label;
            }

            if (descriptionEl instanceof HTMLElement) {
              descriptionEl.textContent = active.dataset.description ?? "";
            }

            return active;
          };

          items.forEach((item) => {
            const label = item.dataset.label || menuDefaultLabel;
            item.addEventListener("mouseenter", () => setPreview(label));
            item.addEventListener("focus", () => setPreview(label));
          });

          if (nav instanceof HTMLElement) {
            nav.addEventListener("mouseleave", () => setPreview(menuDefaultLabel));
          }

          setPreview(menuDefaultLabel);

          return { items, setPreview };
        };

        const previewMenu = bindPreviewMenu(root.querySelector("[data-preview-menu-root]"));

        const closeMenu = () => {
          root.classList.remove("is-open");
          document.body.classList.remove("has-corner-menu-open");
          overlay.hidden = true;
          trigger.setAttribute("aria-expanded", "false");
          trigger.focus();
        };

        const openMenu = () => {
          root.classList.add("is-open");
          document.body.classList.add("has-corner-menu-open");
          overlay.hidden = false;
          trigger.setAttribute("aria-expanded", "true");
          const activeItem = previewMenu?.setPreview(defaultLabel);
          if (activeItem instanceof HTMLAnchorElement) {
            activeItem.focus();
          }
        };

        trigger.addEventListener("click", () => {
          if (root.classList.contains("is-open")) {
            closeMenu();
          } else {
            openMenu();
          }
        });

        closeButtons.forEach((button) => {
          if (button instanceof HTMLElement) {
            button.addEventListener("click", closeMenu);
          }
        });

        previewMenu?.items.forEach((item) => {
          if (!(item instanceof HTMLElement)) {
            return;
          }

          item.addEventListener("click", closeMenu);
        });

        document.addEventListener("keydown", (event) => {
          if (event.key === "Escape") {
            closeMenu();
          }
        });
      };

      const setupInlinePreviewMenus = () => {
        const roots = document.querySelectorAll("[data-preview-menu-root]");
        roots.forEach((root) => {
          if (!(root instanceof HTMLElement) || root.closest("[data-corner-menu-root]")) {
            return;
          }

          if (root.dataset.previewBound === "true") {
            return;
          }

          const nav = root.querySelector("[data-menu-nav]");
          const items = Array.from(root.querySelectorAll("[data-menu-item]")).filter(
            (item) => item instanceof HTMLElement,
          );
          const titleEl = root.querySelector("[data-menu-preview-title]");
          const descriptionEl = root.querySelector("[data-menu-preview-description]");
          const defaultLabel = root.dataset.defaultLabel ?? "About";

          const getItemByLabel = (label) =>
            items.find((item) => item instanceof HTMLElement && item.dataset.label === label);

          const setPreview = (label) => {
            const active = getItemByLabel(label);
            if (!(active instanceof HTMLElement)) {
              return;
            }

            items.forEach((item) => {
              if (item instanceof HTMLElement) {
                item.classList.toggle("is-active", item === active);
              }
            });

            if (titleEl instanceof HTMLElement) {
              titleEl.textContent = active.dataset.title ?? label;
            }

            if (descriptionEl instanceof HTMLElement) {
              descriptionEl.textContent = active.dataset.description ?? "";
            }
          };

          root.dataset.previewBound = "true";
          items.forEach((item) => {
            const label = item.dataset.label || defaultLabel;
            item.addEventListener("mouseenter", () => setPreview(label));
            item.addEventListener("focus", () => setPreview(label));
          });

          if (nav instanceof HTMLElement) {
            nav.addEventListener("mouseleave", () => setPreview(defaultLabel));
          }

          setPreview(defaultLabel);
        });
      };

      const setupBackLink = () => {
        const backLink = document.querySelector("[data-site-back]");

        if (!(backLink instanceof HTMLAnchorElement) || backLink.dataset.backReady === "true") {
          return;
        }

        backLink.dataset.backReady = "true";

        backLink.addEventListener("click", (event) => {
          if (
            event.defaultPrevented ||
            event.button !== 0 ||
            event.metaKey ||
            event.ctrlKey ||
            event.shiftKey ||
            event.altKey
          ) {
            return;
          }

          const referrer = document.referrer;
          const hasSameOriginReferrer =
            referrer &&
            (() => {
              try {
                return new URL(referrer).origin === window.location.origin;
              } catch {
                return false;
              }
            })();

          if (window.history.length > 1 && hasSameOriginReferrer) {
            event.preventDefault();
            window.history.back();
          }
        });
      };

      const setupContactForm = () => {
        const form = document.querySelector(".home-contact-band__form");
        if (!(form instanceof HTMLFormElement) || form.dataset.contactReady === "true") {
          return;
        }

        form.dataset.contactReady = "true";
        form.action = "https://formsubmit.co/markjayson@markjayson.com";
        form.method = "post";

        const upsertHidden = (name, value) => {
          let input = form.querySelector(`input[type="hidden"][name="${name}"]`);
          if (!(input instanceof HTMLInputElement)) {
            input = document.createElement("input");
            input.type = "hidden";
            input.name = name;
            form.prepend(input);
          }
          input.value = value;
          return input;
        };

        const firstName =
          form.querySelector('input[name="first_name"]') ?? form.querySelector('input[name="first-name"]');
        const lastName =
          form.querySelector('input[name="last_name"]') ?? form.querySelector('input[name="last-name"]');
        const email = form.querySelector('input[name="email"]');
        const subject = form.querySelector('input[name="subject"]');
        const message = form.querySelector('textarea[name="message"]');
        const submit = form.querySelector(".home-contact-band__submit");

        if (firstName instanceof HTMLInputElement) {
          firstName.name = "first_name";
          firstName.required = true;
          firstName.autocomplete = "given-name";
        }

        if (lastName instanceof HTMLInputElement) {
          lastName.name = "last_name";
          lastName.required = true;
          lastName.autocomplete = "family-name";
        }

        if (email instanceof HTMLInputElement) {
          email.required = true;
          email.autocomplete = "email";
        }

        if (subject instanceof HTMLInputElement) {
          subject.autocomplete = "off";
        }

        if (message instanceof HTMLTextAreaElement) {
          message.required = true;
        }

        const nextUrl = new URL(window.location.href);
        nextUrl.searchParams.set("contact", "sent");
        nextUrl.hash = "contact";

        upsertHidden("_subject", "New message from markjayson.com");
        upsertHidden("_template", "table");
        upsertHidden("_url", "https://markjayson.com/");
        upsertHidden("_next", nextUrl.toString());

        let honey = form.querySelector('input[type="hidden"][name="_honey"]');
        if (!(honey instanceof HTMLInputElement)) {
          honey = document.createElement("input");
          honey.type = "text";
          honey.name = "_honey";
          honey.tabIndex = -1;
          honey.autocomplete = "off";
          honey.className = "home-contact-band__honeypot";
          form.prepend(honey);
        }

        let status = form.parentElement?.querySelector("[data-contact-status]");
        if (!(status instanceof HTMLElement) && form.parentElement instanceof HTMLElement) {
          status = document.createElement("p");
          status.className = "home-contact-band__status";
          status.dataset.contactStatus = "true";
          status.hidden = true;
          status.setAttribute("aria-live", "polite");
          status.textContent = "Thank you. Your message has been sent.";
          form.parentElement.insertBefore(status, form);
        }

        if (status instanceof HTMLElement) {
          const params = new URLSearchParams(window.location.search);
          status.hidden = params.get("contact") !== "sent";
        }

        if (submit instanceof HTMLButtonElement) {
          form.addEventListener(
            "submit",
            () => {
              submit.disabled = true;
              submit.textContent = "Sending...";
            },
            { once: true },
          );
        }
      };

      const setupSiteTopRowMenuLaunch = () => {
        const launchers = document.querySelectorAll("[data-site-menu-launch]");
        const trigger = document.querySelector("[data-corner-menu-trigger]");

        if (!(trigger instanceof HTMLButtonElement)) {
          return;
        }

        launchers.forEach((launcher) => {
          if (!(launcher instanceof HTMLButtonElement) || launcher.dataset.bound === "true") {
            return;
          }

          launcher.dataset.bound = "true";
          launcher.addEventListener("click", () => trigger.click());
        });
      };

      document.addEventListener("DOMContentLoaded", setupCornerMenu);
      document.addEventListener("astro:page-load", setupCornerMenu);
      document.addEventListener("DOMContentLoaded", setupInlinePreviewMenus);
      document.addEventListener("astro:page-load", setupInlinePreviewMenus);
      document.addEventListener("DOMContentLoaded", setupContactForm);
      document.addEventListener("astro:page-load", setupContactForm);
      document.addEventListener("DOMContentLoaded", setupBackLink);
      document.addEventListener("astro:page-load", setupBackLink);
      document.addEventListener("DOMContentLoaded", setupSiteTopRowMenuLaunch);
      document.addEventListener("astro:page-load", setupSiteTopRowMenuLaunch);
    </script>

    {replicaMotion && <ReplicaMotion />}
  </body>
</html>
