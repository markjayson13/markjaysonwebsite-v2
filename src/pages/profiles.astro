---
import BaseLayout from "../layouts/BaseLayout.astro";
import { profilesPage } from "../data/editorial";
import { buildPrimaryImageStructuredData, buildProfilePageStructuredData, socialPreviewImages } from "../data/site";

const pageTitle = "Profiles";
const pageDescription = "Curated profile directory for Mark Jayson Martinez Farol across academic, professional, technical, and creative platforms.";
const siteOrigin = Astro.site ?? new URL("https://markjayson.com");
const pageUrl = new URL(Astro.url.pathname, siteOrigin).toString();
const profilesHeadshot = socialPreviewImages.profiles;
const structuredData = [
  ...buildProfilePageStructuredData(pageUrl, pageTitle, pageDescription),
  ...buildPrimaryImageStructuredData(pageUrl, {
    src: profilesHeadshot.src,
    alt: profilesHeadshot.alt,
    caption: "Primary headshot of Mark Jayson Farol",
  }),
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  page="profiles"
  accent="#efefea"
  shell="bare"
  footer={false}
  replicaFooter={false}
  replicaMotion={true}
  structuredData={structuredData}
  socialImage={profilesHeadshot}
>
  <article class="replica-page profiles-page profiles-page--canva">
    <div class="replica-canvas profiles-page__canvas">
      <header class="profiles-page__header">
        <h1 class="profiles-page__title" data-lift>{profilesPage.title}</h1>
        <p class="profiles-page__lead" data-lift>{profilesPage.lead}</p>
      </header>

      <div class="profiles-page__grid" role="list">
        {
          profilesPage.buttons.map((button) =>
            button.href ? (
              <a class="profiles-page__button" href={button.href} target="_blank" rel="noreferrer" data-lift role="listitem">
                <span class="profiles-page__symbol">{button.symbol}</span>
                <span>{button.label}</span>
              </a>
            ) : (
              <span class="profiles-page__button profiles-page__button--disabled" data-lift role="listitem">
                <span class="profiles-page__symbol">{button.symbol}</span>
                <span>{button.label}</span>
              </span>
            )
          )
        }
      </div>

      {
        profilesPage.secondaryLinks?.length ? (
          <div class="profiles-page__secondary" data-lift>
            <p class="profiles-page__secondary-label">Archive</p>
            <div class="profiles-page__secondary-links">
              {
                profilesPage.secondaryLinks.map((link) => (
                  <a class="profiles-page__secondary-link" href={link.href} target="_blank" rel="noreferrer">
                    <span>{link.label}</span>
                    <span class="profiles-page__secondary-note">{link.note}</span>
                  </a>
                ))
              }
            </div>
          </div>
        ) : null
      }
    </div>
  </article>
</BaseLayout>
