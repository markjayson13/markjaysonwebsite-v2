---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { creativeCluster, replicaFooterCredit } from "../../data/editorial";
import { buildImageCollectionPageStructuredData, socialPreviewImages } from "../../data/site";
import type { CreativeGalleryItem } from "../../data/editorial";

const photoshootsPage = creativeCluster.photoshoots;
const photoshootGroups = photoshootsPage.groups.map((group) => ({
  ...group,
  items: group.items as CreativeGalleryItem[],
}));
const pageTitle = "Photoshoots";
const pageDescription = "Categorized photoshoots for Mark Jayson Martinez Farol.";
const siteOrigin = Astro.site ?? new URL("https://markjayson.com");
const pageUrl = new URL(Astro.url.pathname, siteOrigin).toString();
const allPhotoshootItems = photoshootGroups.reduce<CreativeGalleryItem[]>(
  (items, group) => items.concat(group.items),
  [],
);
const structuredData = buildImageCollectionPageStructuredData(
  pageUrl,
  pageTitle,
  pageDescription,
  allPhotoshootItems,
);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  page={photoshootsPage.theme.page}
  accent={photoshootsPage.theme.accent}
  shell="bare"
  footer={false}
  replicaFooter={false}
  replicaMotion={true}
  structuredData={structuredData}
  socialImage={socialPreviewImages.creativePhotoshoots}
>
  <article class="replica-page creative-cluster-page creative-photos-page">
    <div class="replica-canvas creative-cluster-page__canvas">
      <div class="creative-cluster-page__shell">
        <header class="creative-photos-page__hero" data-lift>
          <div class="creative-photos-page__hero-copy">
            <p class="creative-photos-page__eyebrow">Mark Jayson Farol</p>
            <h1 class="creative-page__title">{photoshootsPage.title}</h1>
          </div>
        </header>

        <div class="creative-photos-page__layout" data-section-rail-root data-default-panel={photoshootsPage.defaultId}>
          <nav class="creative-photos-page__tabs" aria-label="Photoshoot categories">
            <div class="creative-photos-page__tabs-inner" role="tablist" aria-label="Photoshoot filters" aria-orientation="horizontal">
              {
                photoshootsPage.rail.map((item) => (
                  <button
                    type="button"
                    id={`rail-tab-${item.id}`}
                    class:list={["creative-photos-page__tab", item.id === photoshootsPage.defaultId && "is-active"]}
                    data-rail-link
                    data-target={item.id}
                    role="tab"
                    aria-controls={`rail-panel-${item.id}`}
                    aria-selected={item.id === photoshootsPage.defaultId ? "true" : "false"}
                    tabindex={item.id === photoshootsPage.defaultId ? "0" : "-1"}
                  >
                    {item.label}
                  </button>
                ))
              }
            </div>
          </nav>

          <div class="rail-page__content creative-photos-page__content">
            {
              photoshootGroups.map((group) => {
                return (
                  <section
                    id={`rail-panel-${group.id}`}
                    class="rail-page__group creative-photos-page__panel"
                    data-rail-panel
                    data-section-id={group.id}
                    role="tabpanel"
                    aria-labelledby={`rail-tab-${group.id}`}
                    hidden={group.id !== photoshootsPage.defaultId}
                  >
                    <div class="creative-photos-page__panel-copy" data-lift>
                      <p class="creative-cluster-page__section-label">Series</p>
                      <h2 class="rail-page__group-title">{group.label}</h2>
                      <p class="rail-page__group-intro">{group.intro}</p>
                    </div>

                    <div class="creative-gallery creative-gallery--photos creative-photos-page__gallery">
                      {
                        group.items.map((item, index) => (
                          <figure
                            class:list={[
                              "creative-gallery__figure",
                              "creative-photos-page__figure",
                              item.aspect === "landscape" && "creative-gallery__figure--landscape",
                              item.aspect === "portrait" && "creative-gallery__figure--portrait",
                            ]}
                            data-lift
                          >
                            <img
                              class:list={[
                                "creative-gallery__image",
                                "creative-photos-page__image",
                                item.aspect === "landscape" && "creative-gallery__image--landscape",
                                item.aspect === "portrait" && "creative-gallery__image--portrait",
                              ]}
                              src={item.src}
                              alt={item.alt}
                              loading={index === 0 && group.id === photoshootsPage.defaultId ? "eager" : "lazy"}
                              decoding="async"
                              fetchpriority={index === 0 && group.id === photoshootsPage.defaultId ? "high" : undefined}
                            />
                          </figure>
                        ))
                      }
                    </div>
                  </section>
                );
              })
            }
          </div>
        </div>
      </div>

      <p class="page-credit page-credit--light">{replicaFooterCredit}</p>
    </div>
  </article>
</BaseLayout>
