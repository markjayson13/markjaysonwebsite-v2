---
const destination = "/portfolio#research";
const canonical = `https://markjayson.com${destination}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Redirecting to Portfolio Research</title>
    <meta name="robots" content="noindex,follow" />
    <link rel="canonical" href={canonical} />
    <meta http-equiv="refresh" content={`0;url=${destination}`} />
    <script is:inline>
      window.location.replace("/portfolio#research");
    </script>
  </head>
  <body>
    <p>Redirecting to <a href={destination}>Portfolio Research</a>.</p>
  </body>
</html>
