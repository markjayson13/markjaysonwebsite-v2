---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { creativeCluster, replicaFooterCredit } from "../../data/editorial";
import { buildImageCollectionPageStructuredData, socialPreviewImages } from "../../data/site";

const headshotsPage = creativeCluster.headshots;
const pageTitle = "Headshots";
const pageDescription = "Headshots and portrait studies for Mark Jayson Martinez Farol.";
const siteOrigin = Astro.site ?? new URL("https://markjayson.com");
const pageUrl = new URL(Astro.url.pathname, siteOrigin).toString();
const structuredData = buildImageCollectionPageStructuredData(pageUrl, pageTitle, pageDescription, headshotsPage.items);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  page={headshotsPage.theme.page}
  accent={headshotsPage.theme.accent}
  shell="bare"
  footer={false}
  replicaFooter={false}
  replicaMotion={true}
  structuredData={structuredData}
  socialImage={socialPreviewImages.creativeHeadshots}
>
  <article class="replica-page creative-cluster-page creative-gallery-page">
    <div class="replica-canvas creative-cluster-page__canvas">
      <div class="creative-cluster-page__shell">
        <header class="creative-headshots__hero" aria-labelledby="creative-headshots-hero-title" data-lift>
          <div class="creative-headshots__hero-copy">
            <h1 id="creative-headshots-hero-title" class="creative-page__title">{headshotsPage.title}</h1>
          </div>
        </header>

        <section class="creative-headshots__stage" aria-labelledby="creative-headshots-gallery-title">
          <h2 id="creative-headshots-gallery-title" class="sr-only">Headshot gallery</h2>
          {
            headshotsPage.items.map((item, index) => (
              <figure class="creative-gallery__figure creative-headshots__card" data-lift>
                <img
                  class="creative-gallery__image creative-headshots__gallery-image"
                  src={item.src}
                  alt={item.alt}
                  loading={index === 0 ? "eager" : "lazy"}
                  decoding="async"
                  fetchpriority={index === 0 ? "high" : undefined}
                />
                <details class="creative-media-details creative-media-details--light">
                  <summary>{item.detailsLabel ?? "Details"}</summary>
                  <div class="creative-media-details__body">
                    <p>{item.detailsText ?? item.caption}</p>
                    {item.instagramHref && (
                      <a href={item.instagramHref} target="_blank" rel="noreferrer">
                        Instagram
                      </a>
                    )}
                  </div>
                </details>
              </figure>
            ))
          }
        </section>
      </div>

      <p class="page-credit page-credit--light">{replicaFooterCredit}</p>
    </div>
  </article>
</BaseLayout>
