---
import { navLinks, profile } from "../data/site";
import { withBase } from "../utils/paths";

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;


const normalize = (value: string) =>
  value !== "/" && value.endsWith("/") ? value.slice(0, -1) : value;

const homeHref = withBase("/");
const normalizedCurrentPath = normalize(currentPath);

const isActive = (href: string) => {
  const target = normalize(href);
  if (target === normalize(homeHref)) {
    return normalizedCurrentPath === target;
  }
  return normalizedCurrentPath === target || normalizedCurrentPath.startsWith(`${target}/`);
};
---

<header class="site-nav">
  <div class="site-nav__inner">
    <a class="brand" href={homeHref}>
      <span class="brand__mark">{profile.shortName}</span>
      <span class="brand__copy">
        <strong>{profile.name}</strong>
        <small>{profile.title}</small>
      </span>
    </a>

    <nav class="nav-links" aria-label="Primary">
      {
        navLinks.map((link) => (
          <a
            class:list={["nav-link", { "nav-link--active": isActive(link.href) }]}
            href={link.href}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="nav-meta">
      <span class="nav-meta__label">Now</span>
      <strong>{profile.relocation}</strong>
    </div>
  </div>
</header>
