---
import BaseLayout from "../layouts/BaseLayout.astro";
import { homePage, replicaFooterCredit } from "../data/editorial";
---

<BaseLayout
  title="Homepage"
  description="Homepage for Mark Jayson Martinez Farol."
  page="home"
  accent="#050505"
  shell="bare"
  footer={false}
  replicaFooter={false}
  replicaMotion={true}
>
  <div class="replica-page home-page home-replica">
    <section class="home-hero-band" data-home-hero>
      <div class="replica-canvas home-hero-band__canvas">
        <h1 class="sr-only">Mark Jayson Martinez Farol</h1>

        <div class="home-hero-band__headline-row">
          <p class="home-hero-band__headline-top" aria-hidden="true" data-home-stagger>
            {homePage.hero.headlineTop}
          </p>

          <button class="home-hero-band__contact" type="button" data-contact-trigger data-home-stagger>
            {homePage.hero.ctaLabel}
          </button>
        </div>

        <div class="home-hero-band__frame" data-home-stagger>
          <div class="home-hero-band__frame-title" aria-hidden="true">
            {
              homePage.hero.headlineFrame.map((line) => (
                <span class="home-hero-band__frame-line">{line}</span>
              ))
            }
          </div>

          <div class="home-hero-band__media">
            <video
              class="home-hero-band__video"
              autoplay
              muted
              loop
              playsinline
              preload="auto"
              data-start-time="1.65"
              disablePictureInPicture
              disableRemotePlayback
              aria-hidden="true"
            >
              <source src={homePage.hero.videoSrc} type="video/mp4" />
            </video>
            <div class="home-hero-band__shade"></div>
          </div>

          <div class="home-hero-band__roles" data-home-stagger>
            {
              homePage.hero.roles.map((role) => (
                <span class="home-hero-band__role">{role}</span>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section class="home-discovery-band" data-home-discovery>
      <div class="replica-canvas home-discovery-band__canvas">
        <div
          class="replica-menu-sheet replica-menu-sheet--inline"
          data-preview-menu-root
          data-default-label={homePage.discovery.defaultLabel}
          data-home-reveal
        >
          <h2 class="replica-menu-sheet__title">{homePage.discovery.title}</h2>

          <div class="replica-menu-sheet__layout">
            <nav class="replica-menu-sheet__nav" aria-label="Homepage discovery navigation" data-menu-nav>
              {
                homePage.discoveryItems.map((item) => (
                  <a
                    href={item.href}
                    class="replica-menu-sheet__link"
                    data-menu-item
                    data-title={item.title}
                    data-description={item.description}
                    data-label={item.label}
                  >
                    {item.label}
                  </a>
                ))
              }
            </nav>

            <div class="replica-menu-sheet__preview">
              <h3 data-menu-preview-title></h3>
              <p data-menu-preview-description></p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="home-contact-band" id="contact" data-home-contact>
      <video
        class="home-contact-band__video"
        autoplay
        muted
        loop
        playsinline
        preload="auto"
        disablePictureInPicture
        disableRemotePlayback
        aria-hidden="true"
      >
        <source src={homePage.contact.videoSrc} type="video/mp4" />
      </video>
      <div class="home-contact-band__shade"></div>

      <div class="replica-canvas home-contact-band__canvas">
        <div class="home-contact-band__content" data-home-reveal>
          <div class="home-contact-band__portrait">
            <img src={homePage.contact.portraitSrc} alt="Mark Jayson Farol holding a glowing globe." loading="eager" />
          </div>

          <div class="home-contact-band__form-block">
            <div class="home-contact-band__heading">
              <h2>{homePage.contact.title}</h2>
              <p>{homePage.contact.copy}</p>
            </div>

            <form
              class="home-contact-band__form"
              action="https://formsubmit.co/markjayson@markjayson.com"
              method="post"
            >
              <input type="hidden" name="_subject" value="New message from markjayson.com" />
              <input type="hidden" name="_template" value="table" />
              <input type="hidden" name="_url" value="https://markjayson.com/" />
              <input type="text" name="_honey" class="home-contact-band__honeypot" tabindex="-1" autocomplete="off" />

              <label class="home-contact-band__field">
                <span>First Name*</span>
                <input type="text" name="first_name" required autocomplete="given-name" />
              </label>

              <label class="home-contact-band__field">
                <span>EMAIL*</span>
                <input type="email" name="email" required autocomplete="email" />
              </label>

              <label class="home-contact-band__field home-contact-band__field--message">
                <span>Message</span>
                <textarea name="message" required></textarea>
              </label>

              <label class="home-contact-band__field">
                <span>Last Name*</span>
                <input type="text" name="last_name" required autocomplete="family-name" />
              </label>

              <label class="home-contact-band__field">
                <span>Subject</span>
                <input type="text" name="subject" autocomplete="off" />
              </label>

              <button class="home-contact-band__submit" type="submit">{homePage.contact.submitLabel}</button>
            </form>
          </div>
        </div>

        <p class="page-credit page-credit--light" data-home-reveal>{replicaFooterCredit}</p>
      </div>
    </section>
  </div>
</BaseLayout>
