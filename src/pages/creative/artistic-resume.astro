---
import CreativeClusterNav from "../../components/CreativeClusterNav.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { creativeCluster, replicaFooterCredit } from "../../data/editorial";

const artisticResume = creativeCluster.artisticResume;
---

<BaseLayout
  title="Artistic Resume"
  description="Artistic resume for Mark Jayson Martinez Farol."
  page="creative"
  accent="#ba9838"
  shell="bare"
  footer={false}
  replicaFooter={false}
  replicaMotion={true}
>
  <article class="replica-page creative-cluster-page creative-resume-page">
    <div class="replica-canvas creative-cluster-page__canvas">
      <div class="creative-cluster-page__shell">
        <CreativeClusterNav items={creativeCluster.nav} activeHref={creativeCluster.nav[1].href} />

        <header class="creative-cluster-page__header creative-cluster-page__header--narrow">
          <p class="creative-page__eyebrow" data-lift>Creative Resume</p>
          <h1 class="creative-page__title" data-lift>{artisticResume.title}</h1>
          <p class="creative-cluster-page__lead" data-lift>{artisticResume.lead}</p>
        </header>

        <nav class="creative-resume-page__jump" aria-label="Artistic resume sections">
          {
            artisticResume.sections.map((section) => (
              <a class="creative-resume-page__jump-link" href={`#${section.id}`}>
                {section.label}
              </a>
            ))
          }
        </nav>

        <div class="creative-resume-page__sections">
          {
            artisticResume.sections.map((section) => (
              <section id={section.id} class="creative-resume-page__section">
                <header class="creative-resume-page__section-header" data-lift>
                  <p class="creative-cluster-page__section-label">{section.label}</p>
                  <h2 class="creative-resume-page__section-title">{section.label}</h2>
                  <p class="creative-resume-page__section-intro">{section.intro}</p>
                </header>

                <div class="creative-resume-page__entries">
                  {
                    section.entries.map((entry) => (
                      <article class="creative-resume-card" data-lift>
                        <h3>{entry.title}</h3>
                        {entry.subtitle && <p class="creative-resume-card__subtitle">{entry.subtitle}</p>}
                        {entry.meta && <p class="creative-resume-card__meta">{entry.meta}</p>}
                        {entry.description && <p>{entry.description}</p>}
                      </article>
                    ))
                  }
                </div>
              </section>
            ))
          }
        </div>
      </div>

      <p class="page-credit page-credit--light">{replicaFooterCredit}</p>
    </div>
  </article>
</BaseLayout>
